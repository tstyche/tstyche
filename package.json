{
  "name": "tstyche",
  "version": "7.2.1",
  "description": "Everything You Need for Type Testing.",
  "keywords": [
    "typescript",
    "types",
    "test",
    "runner",
    "expect"
  ],
  "homepage": "https://tstyche.org",
  "bugs": {
    "url": "https://github.com/tstyche/tstyche/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tstyche/tstyche.git"
  },
  "funding": "https://github.com/tstyche/tstyche?sponsor=1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./api": "./dist/api.js",
    "./tag": "./dist/tag.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/bin.js",
  "files": [
    "dist/**/*",
    "schemas/*.json"
  ],
  "scripts": {
    "build": "rollup --config ./.rollup/config.ts",
    "format": "biome format --write",
    "generate": "aube generate:schemas && aube generate:types",
    "generate:schemas": "node ./.aube/generate-schemas.ts",
    "generate:types": "node ./.aube/generate-types.ts",
    "lint": "biome lint --write",
    "prepublish": "aube build",
    "test": "aube test:unit && aube test:e2e",
    "test:e2e": "aube test:run tests/*.test.js",
    "test:examples": "tstyche examples",
    "test:run": "node ./tests/__utilities__/runner.js",
    "test:schemas": "jsonschema test schemas/__tests__/*.test.json",
    "test:types": "tstyche typetests",
    "test:unit": "aube test:run source/**/__tests__/*.test.js --parallel",
    "typecheck": "tsc --build --force --verbose"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@sourcemeta/jsonschema": "^15.8.0",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "^7.0.0-dev.20260609.1",
    "cleaner-spec-reporter": "^1.0.3",
    "code-block-writer": "^13.0.3",
    "magic-string": "0.30.21",
    "monocart-coverage-reports": "^2.12.12",
    "pretty-ansi": "^4.0.0",
    "rollup": "^4.61.1",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
