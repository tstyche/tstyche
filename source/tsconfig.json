{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["es2024"],
    "module": "node16",
    "moduleResolution": "node16",

    "declaration": true,
    "noEmit": false,
    "outDir": "../dist",
    "preserveConstEnums": true,
    "removeComments": true,
    "verbatimModuleSyntax": false, // otherwise const enums are not inlined, unfortunately

    "jsx": "react-jsx",
    "jsxImportSource": "#scribbler",

    "skipLibCheck": false
  },
  "include": ["**/*"],
  "exclude": ["**/__tests__/**/*"]
}
